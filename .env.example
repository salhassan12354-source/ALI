# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# OPENR_API_KEY: Required for OpenRouter (Nemotron model in ALI5.7 BETA).
OPENR_API_KEY=

# NVIDIA_API_KEY: Required for NVIDIA AI (ALI5.7 BETA).
NVIDIA_API_KEY=

# NVIDIA_API_KEY_ALI46: Required for NVIDIA AI (ALI4.6).
NVIDIA_API_KEY_ALI46=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
